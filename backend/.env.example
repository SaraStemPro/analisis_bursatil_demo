# Supabase PostgreSQL
# Encuentra estos datos en: supabase.com → tu proyecto → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_ID.supabase.co:5432/postgres

# JWT
JWT_SECRET_KEY=cambiar-en-produccion-usar-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM (Tutor IA) — configurar cuando lleguemos a esa fase
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=all-MiniLM-L6-v2
